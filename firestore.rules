rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - xp: number (required)
    //   - level: number (required)
    //   - avatar: map
    //   - stats: map
    //
    // Collection: /users/{userId}/tasks/{taskId}
    // Fields:
    //   - uid: string (required)
    //   - title: string (required)
    //   - category: string (enum)
    //   - priority: string (enum)
    //   - deadline: timestamp
    //   - completed: bool (required)
    //   - xpReward: number (required)
    //   - createdAt: timestamp
    //
    // [Other collections follow similar patterns]
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'xp', 'level']) &&
             data.uid is string &&
             data.xp is number &&
             data.level is number;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['uid', 'title', 'completed', 'xpReward']) &&
             data.uid is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.completed is bool &&
             data.xpReward is number;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);

      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTask(request.resource.data);
        allow update: if isOwner(userId) && isValidTask(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /habits/{habitId} {
        allow read, write: if isOwner(userId);
      }

      match /skills/{skillId} {
        allow read, write: if isOwner(userId);
      }

      match /journal/{entryId} {
        allow read, write: if isOwner(userId);
      }

      match /achievements/{achievementId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
      }

      match /focusSessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
